# Humanitarian MCP — configuration
# Every variable is optional; defaults are sensible for local use.

# Comma-separated list of enabled providers (default: unhcr,worldbank)
# unhcr     — UNHCR Refugee Statistics (displacement, demographics, asylum)
# worldbank — World Bank context indicators (population, GDP, poverty) — powers normalize_by
# hdx       — HDX HAPI (IDPs, conflict events, funding, food security) — needs HMCP_HDX_APP_ID
# reliefweb — ReliefWeb situation reports (counts + latest links) — needs HMCP_RELIEFWEB_APPNAME
HMCP_PROVIDERS=unhcr,worldbank

# HDX HAPI app identifier — required only when the hdx provider is enabled.
# Free: https://hapi.humdata.org/docs#/Generate%20App%20Identifier
# (it is base64 of "your-app-name:your-email", not a secret key)
# HMCP_HDX_APP_ID=

# ReliefWeb API appname — required only when the reliefweb provider is enabled.
# Since 1 Nov 2025 appnames must be pre-approved: request one via the short form at
# https://apidoc.reliefweb.int/parameters#appname (ReliefWeb replies by email).
# HMCP_RELIEFWEB_APPNAME=

# Cache backend: memory | sqlite (default: memory)
HMCP_CACHE=memory
# Path for the sqlite cache file (default: .cache/humanitarian-mcp.sqlite)
HMCP_CACHE_PATH=.cache/humanitarian-mcp.sqlite
# Fresh TTL in seconds — entries younger than this are served without a network call (default: 3600)
HMCP_CACHE_TTL=3600
# Stale ceiling in seconds — entries older than TTL but younger than this are served
# stale while a background refresh runs (default: 604800 = 7 days)
HMCP_CACHE_STALE_TTL=604800

# Offline mode: 1 = never touch the network, serve from cache only (default: 0)
HMCP_OFFLINE=0

# Max outgoing requests per second per provider (default: 4)
HMCP_RATE_LIMIT_RPS=4

# Log level: debug | info | warn | error (default: info). Logs go to stderr.
HMCP_LOG_LEVEL=info

# In-memory usage analytics for the demo dashboard: 1 = on (default: 1)
HMCP_ANALYTICS=1

# Port for --http mode (streamable MCP endpoint + demo dashboard) (default: 8642)
HMCP_HTTP_PORT=8642

# Interface to bind in --http mode (default: 127.0.0.1 — safe behind a reverse proxy).
# Set 0.0.0.0 only if you intentionally expose the port directly.
# HMCP_HTTP_HOST=127.0.0.1

# Inbound rate limit in --http mode: max requests per minute per client IP,
# applied to /mcp and /api/* (GET /health is always exempt). 0 disables it.
# The client IP is read from X-Forwarded-For when present — make sure your
# reverse proxy sets it; without a proxy, clients able to forge the header
# can dodge the limiter. (default: 120)
HMCP_HTTP_RATE_LIMIT_RPM=120

# Override the User-Agent sent to data providers
# HMCP_USER_AGENT=humanitarian-mcp/0.1.0 (+https://github.com/ahmedvnabil/humanitarian-mcp)
